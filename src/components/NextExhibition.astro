---
interface Props {
  previousTitle?: string;
  previousLink?: string;

  nextTitle?: string;
  nextLink?: string;
}

const {
  previousTitle,
  previousLink,
  nextTitle,
  nextLink
} = Astro.props;
---

<section class="continue">

  <p class="label">
    CONTINUE THROUGH THE ARCHIVE
  </p>

  <div class="navigation">

    <div class="previous">

      {
        previousTitle && (
          <>
            <span>PREVIOUS EXHIBITION</span>

            <a href={previousLink}>
              ← {previousTitle}
            </a>
          </>
        )
      }

    </div>

    <div class="next">

      {
        nextTitle && (
          <>
            <span>NEXT EXHIBITION</span>

            <a href={nextLink}>
              {nextTitle} →
            </a>
          </>
        )
      }

    </div>

  </div>

</section>

<style>

.continue{

padding:180px 8%;
border-top:1px solid #222;

}

.label{

text-align:center;
letter-spacing:8px;
color:#B89D68;
margin-bottom:80px;

}

.navigation{

display:flex;
justify-content:space-between;
gap:40px;

}

.previous,
.next{

flex:1;

}

.previous span,
.next span{

display:block;
letter-spacing:4px;
color:#777;
margin-bottom:15px;

}

.previous a,
.next a{

font-size:2rem;
text-decoration:none;
color:white;
transition:.3s;

}

.previous a:hover,
.next a:hover{

color:#B89D68;

}

.next{

text-align:right;

}

@media(max-width:900px){

.navigation{

flex-direction:column;
text-align:left;

}

.next{

text-align:left;

}

}

</style>