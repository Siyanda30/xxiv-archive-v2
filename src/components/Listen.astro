---
interface Props {
  spotify: string;
  apple: string;
  youtube: string;
}

const { spotify, apple, youtube } = Astro.props;
---

<section class="listen">

  <div class="heading">

    <p>FINAL ROOM</p>

    <h2>Listen to the Exhibition</h2>

    <p class="description">
      The exhibition continues beyond the archive.
      Choose your preferred platform to experience the music.
    </p>

  </div>

  <div class="platforms">

    <a href={spotify} target="_blank">
      Spotify
    </a>

    <a href={apple} target="_blank">
      Apple Music
    </a>

    <a href={youtube} target="_blank">
      YouTube Music
    </a>

  </div>

</section>

<style>

.listen{

padding:180px 8%;
text-align:center;
max-width:1000px;
margin:auto;

}

.heading p:first-child{

letter-spacing:8px;
color:#B89D68;
font-size:.8rem;

}

.heading h2{

font-size:4rem;
font-weight:300;
margin:25px 0;

}

.description{

max-width:650px;
margin:auto;
line-height:2;
color:#999;

}

.platforms{

margin-top:70px;
display:flex;
justify-content:center;
gap:25px;
flex-wrap:wrap;

}

.platforms a{

padding:18px 45px;
border:1px solid #333;
text-decoration:none;
color:white;
letter-spacing:4px;
transition:.3s;

}

.platforms a:hover{

background:#B89D68;
color:black;
border-color:#B89D68;

}

@media(max-width:900px){

.heading h2{

font-size:2.8rem;

}

.platforms{

flex-direction:column;

}

.platforms a{

width:100%;

}

}

</style>